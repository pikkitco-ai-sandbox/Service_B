# Service_B — Chat Gateway / Slack Agent
# Copy this file to .env and fill in values. Never commit .env.

# --- Slack Credentials ---
# Create a Slack app at https://api.slack.com/apps
# Required scopes: chat:write, commands, app_mentions:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Only needed if using Socket Mode (not required for Vercel deploy)
SLACK_APP_TOKEN=xapp-your-app-token

# --- State Adapter ---
# Redis connection for conversation state persistence.
# Omit to use in-memory adapter (dev only, state lost on restart).
REDIS_URL=

# --- Backend API URLs ---
# Base URLs for the Python orchestrator services (no trailing slash).
DUMMY_AGENT_BASE_URL=http://localhost:8000
MISLINK_AGENT_BASE_URL=http://localhost:8001

# --- Feature Flags ---
# Set to "live" to call real backends; "mock" returns stubbed responses.
CHAT_BACKEND_MODE=mock
# Set to "true" to keep legacy Slack paths active in Python repos.
# Turn off once Service_B handles all Slack interactions.
LEGACY_SLACK_ENABLED=true
# Set to "true" to enable the new chat layer in Service_B.
# When false, Service_B still receives events but responds with a "not ready" message.
NEW_CHAT_LAYER_ENABLED=true

# --- CI / Cross-Repo Docs ---
# Fine-grained PAT with contents:write + pull-requests:write on Documentation repo.
DOCS_REPO_PAT=
